# Example inventory file for DynamicRecords playbooks
#
# Copy this file to 'inventory' and customize for your environment
# Usage: ansible-playbook -i inventory playbook.yml

[webservers]
web1.example.com ansible_host=192.0.2.10
web2.example.com ansible_host=192.0.2.11
web3.example.com ansible_host=192.0.2.12

[api_servers]
api1.example.com ansible_host=192.0.2.20
api2.example.com ansible_host=192.0.2.21

[databases]
db1.example.com ansible_host=192.0.2.30 database_port=5432
db2.example.com ansible_host=192.0.2.31 database_port=5432

[blue_servers]
blue1.example.com ansible_host=192.0.2.40
blue2.example.com ansible_host=192.0.2.41

[green_servers]
green1.example.com ansible_host=192.0.2.50
green2.example.com ansible_host=192.0.2.51

[all:vars]
# DynamicRecords API configuration
dns_api_url=https://dns-server.example.com:8053
dns_client_cert=/etc/ssl/certs/dns-client.crt
dns_client_key=/etc/ssl/private/dns-client.key
dns_ca_cert=/etc/ssl/certs/dns-ca.crt

# DNS settings
service_domain=service.local
dns_ttl=300

# Ansible connection settings
ansible_user=admin
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_python_interpreter=/usr/bin/python3
